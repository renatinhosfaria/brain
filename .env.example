POSTGRES_PASSWORD=troque-me
DATABASE_URL=postgresql+asyncpg://brain:troque-me@postgres:5432/brain
OPENAI_API_KEY=sk-...
GITHUB_TOKEN=ghp_...
# BRAIN_AUTH_TOKEN is a migration fallback only when BRAIN_CURATOR_TOKEN is unset.
# It is not a parallel Hermes curator credential.
BRAIN_AUTH_TOKEN=gere-um-token-forte
BRAIN_CURATOR_SLUG=hermes
BRAIN_CURATOR_NAME=Hermes
BRAIN_CURATOR_TOKEN=...
# BRAIN_TOKEN_ENCRYPTION_KEY must be a Fernet key.
# Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BRAIN_TOKEN_ENCRYPTION_KEY=...
WEBHOOK_SECRET=gere-um-segredo
HERMES_WEBHOOK_URL=
HERMES_WEBHOOK_SECRET=
REPO_URL=https://github.com/usuario/brain-vault.git
REPO_CACHE_PATH=repo_cache
GIT_PUSH_ENABLED=true
BRAIN_DOMAIN=brain.seu-dominio.com
BRAIN_HTTP_PORT=80
BRAIN_HTTPS_PORT=443
BRAIN_BACKUP_INTERVAL_SECONDS=86400
BRAIN_BACKUP_RETENTION_DAYS=7
